# Ratio App Backend Configuration
PORT=3000
NODE_ENV=development

# Ratio App Credentials
RATIO_APP_ID=your_app_id
RATIO_APP_SECRET=your_app_secret
RATIO_REDIRECT_URI=http://localhost:3000/auth/callback
# QA:   https://gkx.gokwik.co/aes
# Prod: https://gkx.gokwik.co/aes
RATIO_API_BASE_URL=https://gkx.gokwik.co/aes
RATIO_API_VERSION=v1

# OAuth Tokens (auto-filled by MCP after OAuth flow)
RATIO_ACCESS_TOKEN=
RATIO_REFRESH_TOKEN=
RATIO_MERCHANT_ID=
RATIO_SCOPES=

# JWT
JWT_SECRET=your_jwt_secret_change_this
JWT_EXPIRES_IN=7d

# Hookdeck (managed by MCP — do not edit)
HOOKDECK_URL=
